    file write fh2 "`s'_se," %9.6f (se_`s'_und1) "," %9.6f (se_`s'_und2) "," ///
        %9.6f (se_`s'_spk1) "," %9.6f (se_`s'_spk2) "," ///
        %9.6f (se_`s'_ind1) "," %9.6f (se_`s'_ind2) _n
}
file write fh2 "N," %9.0f (n_und1) "," %9.0f (n_und2) "," ///
    %9.0f (n_spk1) "," %9.0f (n_spk2) "," ///
    %9.0f (n_ind1) "," %9.0f (n_ind2) _n

file close fh2

di as result "========== COMPLETE =========="
di as result "Table written to: $tabs/tabATTcontrols.tex"
