    %9.6f (se_post_ind1) "," %9.6f (se_post_ind2) _n
foreach s in pre tp0 tp1 tp2 tp3 tp4 tp5 tp6 {
    file write fh2 "`s'_b," %9.6f (b_`s'_und1) "," %9.6f (b_`s'_und2) "," ///
