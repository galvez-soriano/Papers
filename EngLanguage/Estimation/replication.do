    ytitle("Absolute Standardized Difference", size(medlarge) margin(medium)) ///
    yscale(range(0 3)) ///
    xlabel(1(1)9, valuelabel labsize(medium) angle(45) noticks) ///
    xtitle("Baseline Covariates", size(medlarge) margin(medium)) ///
    xscale(range(0.5 9.5)) ///
    legend(order(1 "Before Restriction" 2 "After Common Support") ///
           pos(2) ring(0) cols(1) size(medium) region(lcolor(white)) ///
           symxsize(8)) ///
    note("Red dashed line: |std. diff.| = 0.1" ///
