label var dmigrant "Share migrants (baseline)"
label var inactive "Share inactive (baseline)"
label var labor "Share in labor force (baseline)"

*--- PART 3: propensity score (diagnostic pscore plots omitted) ---*
encode state, gen(state_id)
logit treated_mun female age student edu indigenous rural dmigrant inactive labor i.state_id
predict pscore, pr

*--- PART 4: common-support region ---*
quietly sum pscore if treated_mun==1
local min_treated = r(min)
local max_treated = r(max)
quietly sum pscore if treated_mun==0
local min_control = r(min)
local max_control = r(max)
gen common_support = (pscore >= max(`min_treated', `min_control') & ///
                      pscore <= min(`max_treated', `max_control'))
_pctile pscore if treated_mun==1, p(5 95)
local p5_treated = r(r1)
local p95_treated = r(r2)
gen common_support_trim = (pscore >= `p5_treated' & pscore <= `p95_treated')
tab treated_mun common_support
tab treated_mun common_support_trim

*--- PART 5: balance before/after (postfile feeds the love plot) ---*
tempfile balance_before
tempname memhold1
postfile `memhold1' str30 varname mean_control mean_treated diff se pval std_diff using `balance_before'
foreach var in female age student edu indigenous rural dmigrant inactive labor {
    quietly sum `var' if treated_mun==0
    local m0 = r(mean)
    local sd0 = r(sd)
    quietly sum `var' if treated_mun==1
    local m1 = r(mean)
    local sd1 = r(sd)
    quietly ttest `var', by(treated_mun) unequal
    local diff = r(mu_1) - r(mu_2)
    local se = r(se)
    local pval = r(p)
    local std_diff = (`m1' - `m0')/sqrt((`sd1'^2 + `sd0'^2)/2)
    post `memhold1' ("`var'") (`m0') (`m1') (`diff') (`se') (`pval') (`std_diff')
}
postclose `memhold1'

tempfile balance_after
tempname memhold2
postfile `memhold2' str30 varname mean_control mean_treated diff se pval std_diff using `balance_after'
foreach var in female age student edu indigenous rural dmigrant inactive labor {
    quietly sum `var' if treated_mun==0 & common_support==1
    local m0 = r(mean)
    local sd0 = r(sd)
    quietly sum `var' if treated_mun==1 & common_support==1
    local m1 = r(mean)
    local sd1 = r(sd)
    quietly ttest `var' if common_support==1, by(treated_mun) unequal
    local diff = r(mu_1) - r(mu_2)
    local se = r(se)
    local pval = r(p)
    local std_diff = (`m1' - `m0')/sqrt((`sd1'^2 + `sd0'^2)/2)
    post `memhold2' ("`var'") (`m0') (`m1') (`diff') (`se') (`pval') (`std_diff')
}
postclose `memhold2'

*--- PART 6: love plot (FIGURE) ---*
use `balance_before', clear
gen sample = "Before"
save `balance_before', replace
use `balance_after', clear
gen sample = "After"
save `balance_after', replace
use `balance_before', clear
append using `balance_after'

gen order = .
replace order = 1 if varname == "female"
replace order = 2 if varname == "age"
replace order = 3 if varname == "student"
