replace first_cohort=1991 if state=="10" & engl==1
replace first_cohort=1987 if state=="19" & engl==1
replace first_cohort=1993 if state=="25" & engl==1
replace first_cohort=1993 if state=="26" & engl==1
replace first_cohort=1990 if state=="28" & engl==1

destring geo, replace
tempfile maindata
save `maindata', replace

*--- PART 2: baseline municipality characteristics ---*
use `maindata', clear
gen pre_treatment = 0
replace pre_treatment = 1 if state=="01" & cohort < 1990
replace pre_treatment = 1 if state=="10" & cohort < 1991
replace pre_treatment = 1 if state=="19" & cohort < 1987
replace pre_treatment = 1 if state=="25" & cohort < 1993
replace pre_treatment = 1 if state=="26" & cohort < 1993
replace pre_treatment = 1 if state=="28" & cohort < 1990
replace pre_treatment = 1 if first_cohort==0 & cohort < 1987
keep if pre_treatment == 1
collapse (mean) female age student edu indigenous rural dmigrant inactive labor ///
         (first) engl state first_cohort [iw=factor], by(geo)
gen treated_mun = (engl==1 & first_cohort!=0)
label var treated_mun "High-English Municipality"
label var female "Share female (baseline)"
label var age "Average age (baseline)"
label var student "Share students (baseline)"
