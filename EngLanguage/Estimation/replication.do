file write fh_ps "Pre-Treatment Trends&`sfT'&`spT'\\" _n
file write fh_ps "Joint (Levels + Trends)&`sfJ'&`spJ'\\" _n
file write fh_ps "\bottomrule" _n
file write fh_ps "\end{tabular}" _n
file write fh_ps "\begin{tablenotes}[flushleft]" _n
file write fh_ps "\footnotesize" _n
file write fh_ps "\item \textit{Notes:} Each row reports results from regressing treatment status (indicator for high-English instruction municipality) on pre-treatment outcome measures. All regressions control for pre-treatment municipality characteristics (share female, age composition, education, share students, rural status, share migrants, labor force participation, inactive population) and state fixed effects. Pre-treatment levels are municipality averages across pre-treatment cohorts. Pre-treatment trends are estimated coefficients from municipality-specific linear time trends. F-statistics test joint significance of the three outcome measures: understanding indigenous languages, speaking indigenous languages, and indigenous self-identification. Standard errors clustered at state level (29 clusters)." _n
file write fh_ps "\end{tablenotes}" _n
file write fh_ps "\end{threeparttable}" _n
file write fh_ps "\end{table}" _n
file close fh_ps

*------------------------------------------------------------------------*
