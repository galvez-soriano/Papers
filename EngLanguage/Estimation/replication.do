*========================================================================*
* replication.do
*------------------------------------------------------------------------*
* GLOBAL LANGUAGE, LOCAL IDENTITY:
* English Education and Indigenous Skill Formation in Mexico
*
*   Oscar Galvez-Soriano  (University of Chicago)
*   Ornella Darova        (Harvard Kennedy School)
*
* REPLICATION MASTER. One self-contained do-file that regenerates every
* figure and table in the paper produced by this code base.
*
*------------------------------------------------------------------------*
* HOW TO RUN
*   1. Edit the single path on the "global root" line in section 0 below
*      to point to the replication folder on your machine.
*   2. Put the data extracts in  <root>/Input/ :
*         labor_census20.dta   2020 census extract
*         labor_census10.dta   2010 census extract
*         dummies.dta          state industrial / tourism / FDI indicators
*   3. Run in the Stata GUI (StataMP recommended).   *** GUI, NOT -b ***
*      Figure export needs the "Times New Roman" font and the interactive
*      graph engine; batch mode (stata-mp -b) silently drops the font and
*      can fail PNG export with error r(111).
*
* OUTPUT  (created automatically under <root>/Replication_Output/)
*      Replication_Output/figures/   every .png figure
*      Replication_Output/tables/    every .tex table  (+ Table 2 .csv)
*   Point the paper's \graphicspath and \input commands at these folders.
*
* RUNTIME  potentially several days: 90+ Callaway & Sant'Anna event studies,
*   each with a wild cluster bootstrap. 
*   Use the two switches in section 0 to run the tables
*   and the figures separately.
*
*========================================================================*

clear all
set more off

*------------------------------------------------------------------------*
* 0.  PATHS  --  EDIT ONLY THE NEXT LINE
*------------------------------------------------------------------------*
global root "/Users/odarova/Dropbox/IndigenousIdentityMexico"

global data "$root/Input"
global out  "$root/Replication_Output"
global figs "$out/figures"
global tabs "$out/tables"

cap mkdir "$out"
cap mkdir "$figs"
cap mkdir "$tabs"

*------------------------------------------------------------------------*
* 0a.  REQUIRED USER-WRITTEN PACKAGES  (installed once if missing)
*      Needs an internet connection the first time.
*        drdid               dependency of csdid (Callaway-Sant'Anna)
*        colrspace, palettes  dependencies of grstyle (figure styling)
*        eventstudyinteract  Sun-Abraham estimator (Figure 12 SA panels)
*        avar                dependency of eventstudyinteract
*        reghdfe, ftools     used by eventstudyinteract's absorb()
*                            (ftools is a dependency of reghdfe)
*------------------------------------------------------------------------*
foreach pkg in drdid csdid event_plot eventstudyinteract avar reghdfe ftools colrspace palettes grstyle estout {
    capture which `pkg'
    if _rc ssc install `pkg', replace
}

*------------------------------------------------------------------------*
* 0b.  WHAT TO RUN   (1 = run, 0 = skip)
*------------------------------------------------------------------------*
local make_tables  = 1
local make_figures = 1

if `make_tables' == 1 {

*========================================================================*
* PART 1.  TABLES
*========================================================================*

*========================================================================*
* Table 1.  Descriptive statistics (tabIndPop)        [NOT GENERATED HERE]
*   Table 1 is a HAND-BUILT descriptive table (indigenous population shares
*   across the six treated states), assembled directly from the population
*   census rather than by code. It ships with the paper, not with this
*   script. The block below writes a clearly-labelled PLACEHOLDER
*   tabIndPop.tex to $tabs so the LaTeX package still compiles; swap in the
*   paper's hand-made version before distributing the final PDF.
*========================================================================*
file open fh1 using "$tabs/tabIndPop.tex", write replace
file write fh1 "% ---------------------------------------------------------------" _n
file write fh1 "% PLACEHOLDER for Table 1 (tabIndPop)." _n
file write fh1 "% Table 1 is a hand-made descriptive table built directly from the" _n
file write fh1 "% population census; it is NOT regenerated by replication.do." _n
file write fh1 "% Replace this file with the paper's hand-made tabIndPop.tex." _n
file write fh1 "% ---------------------------------------------------------------" _n
file close fh1
di as txt "Table 1: placeholder written (hand-made table, not regenerated) -> $tabs/tabIndPop.tex"

