    replace pre_treatment = 1 if state=="01" & cohort < 1990
    replace pre_treatment = 1 if state=="10" & cohort < 1991
    replace pre_treatment = 1 if state=="19" & cohort < 1987
    replace pre_treatment = 1 if state=="25" & cohort < 1993
    replace pre_treatment = 1 if state=="26" & cohort < 1993
    replace pre_treatment = 1 if state=="28" & cohort < 1990
    keep if inlist(state, "01", "10", "19", "25", "26", "28")
    keep if pre_treatment == 1
    collapse (mean) indig_share=indigenous [iw=factor], by(state geo)
    _pctile indig_share, p(25 50 75)
    gen quartile = 1 if indig_share < r(r1)
    replace quartile = 2 if indig_share >= r(r1) & indig_share < r(r2)
    replace quartile = 3 if indig_share >= r(r2) & indig_share < r(r3)
    replace quartile = 4 if indig_share >= r(r3) & !missing(indig_share)
    tempfile indig_baseline
    save `indig_baseline'
restore

merge m:1 state geo using `indig_baseline'
drop if _merge==2
drop _merge

gen mig_to_quart1 = (dmigrant==1 & quartile==1)
gen mig_to_quart2 = (dmigrant==1 & quartile==2)
gen mig_to_quart3 = (dmigrant==1 & quartile==3)
gen mig_to_quart4 = (dmigrant==1 & quartile==4)

