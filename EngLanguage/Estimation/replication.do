*========================================================================*
* Write the .tex table
*========================================================================*

* p-values for stars (simple, post, pre, tp0-tp6)
foreach spec in und1 und2 spk1 spk2 ind1 ind2 {
    foreach s in simp post pre tp0 tp1 tp2 tp3 tp4 tp5 tp6 {
        scalar z_`s'_`spec' = b_`s'_`spec' / se_`s'_`spec'
        scalar p_`s'_`spec' = 2*(1-normal(abs(z_`s'_`spec')))
    }
}

* helper program to add stars
capture program drop addstars
program define addstars, rclass
    args coef pval
    local s ""
    if `pval' < 0.01 local s "***"
    else if `pval' < 0.05 local s "**"
    else if `pval' < 0.10 local s "*"
    return local formatted = string(`coef', "%7.4f") + "`s'"
end

capture file close fh
file open fh using "$tabs/tabATTcontrols.tex", write replace

file write fh "\begin{table}[htbp]" _n
file write fh "\centering" _n
file write fh "\caption{Average Treatment Effect on the Treated (ATT)}" _n
file write fh "\label{tabATTcontrols}" _n
file write fh "\begin{threeparttable}" _n
file write fh "\begin{tabular}{lcccccc}" _n
file write fh "\hline\hline" _n
file write fh " & \multicolumn{2}{c}{Understanding} & \multicolumn{2}{c}{Speaking} & \multicolumn{2}{c}{Identity} \\" _n
file write fh "\cmidrule(lr){2-3} \cmidrule(lr){4-5} \cmidrule(lr){6-7}" _n
file write fh " & (1) & (2) & (3) & (4) & (5) & (6) \\" _n
file write fh "\hline" _n

* Helper: write one row with coef (stars) and a row with SE in parens
* Arguments: stat-suffix (simp/post/pre/tp0.../tp6) and row label
local rowlabels `" "Simple ATT" "Post-avg (-4 to +6)" "Pre-avg" "t+0" "t+1" "t+2" "t+3" "t+4" "t+5" "t+6" "'
local rowstats  simp post pre tp0 tp1 tp2 tp3 tp4 tp5 tp6
local nrows : word count `rowstats'
forvalues i = 1/`nrows' {
    local s : word `i' of `rowstats'
    local lab : word `i' of `rowlabels'
    file write fh "`lab'"
    foreach spec in und1 und2 spk1 spk2 ind1 ind2 {
        addstars b_`s'_`spec' p_`s'_`spec'
        file write fh " & " "`r(formatted)'"
    }
    file write fh " \\" _n
    file write fh " "
    foreach spec in und1 und2 spk1 spk2 ind1 ind2 {
        file write fh " & (" %7.4f (se_`s'_`spec') ")"
    }
    file write fh " \\" _n
    * Add separator after Simple, Post_avg, Pre_avg
    if `i' <= 3 file write fh "\addlinespace" _n
}
file write fh "\hline" _n

* Controls row
file write fh "Controls & No & Yes & No & Yes & No & Yes \\" _n

* N row
file write fh "Observations"
foreach spec in und1 und2 spk1 spk2 ind1 ind2 {
    file write fh " & " %12.0fc (n_`spec')
}
file write fh " \\" _n

file write fh "\hline\hline" _n
file write fh "\end{tabular}" _n
file write fh "\begin{tablenotes}[flushleft]" _n
file write fh "\footnotesize" _n
file write fh "\item \textit{Notes:} " _n
file write fh "Treatment effects from Callaway and Sant'Anna (2021)." _n
file write fh "Simple ATT is the equally-weighted average across all group-time ATTs." _n
file write fh "Post-avg is the average of event-study coefficients over post-treatment window (-4 to +6)." _n
file write fh "Pre-avg is the analogous average of pre-treatment event-study coefficients (pre-trend diagnostic)." _n
file write fh "Rows t+0 through t+6 are the individual event-study coefficients at each post-treatment period," _n
file write fh "where t+k is the effect for cohorts with k years of post-treatment exposure." _n
file write fh "Controls: education, rural, female, migrant dummy." _n
file write fh "Standard errors clustered at the municipality level with wild bootstrap in parentheses." _n
file write fh "* \$p<0.10\$, ** \$p<0.05\$, *** \$p<0.01\$." _n
file write fh "\end{tablenotes}" _n
file write fh "\end{threeparttable}" _n
file write fh "\end{table}" _n

file close fh

