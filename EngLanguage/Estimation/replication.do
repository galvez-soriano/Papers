replace order = 8 if varname == "inactive"
replace order = 9 if varname == "labor"
gen abs_std_diff = abs(std_diff)
keep varname order abs_std_diff sample
reshape wide abs_std_diff, i(varname order) j(sample) string
twoway (scatter abs_std_diffBefore order, ///
            msymbol(O) mcolor(navy) msize(large) mlwidth(medium)) ///
