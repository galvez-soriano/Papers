*------------------------------------------------------------------------*
use "$data/labor_census20.dta", clear
drop if state=="05" | state=="17"
keep if migrant==0
drop if imputed_state==1

sum hrs_exp2 if state=="01" & cohort>=1990 & cohort<=1996, d
gen engl=hrs_exp2>=r(p50) & state=="01"
sum hrs_exp2 if state=="10" & cohort>=1991 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="10"
sum hrs_exp2 if state=="19" & cohort>=1987 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="19"
sum hrs_exp2 if state=="25" & cohort>=1993 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="25"
sum hrs_exp2 if state=="26" & cohort>=1993 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="26"
sum hrs_exp2 if state=="28" & cohort>=1990 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="28"

gen first_cohort=0
replace first_cohort=1990 if state=="01" & engl==1
replace first_cohort=1991 if state=="10" & engl==1
replace first_cohort=1987 if state=="19" & engl==1
replace first_cohort=1993 if state=="25" & engl==1
replace first_cohort=1993 if state=="26" & engl==1
replace first_cohort=1990 if state=="28" & engl==1

destring geo, replace

*------------------------------------------------------------------------*
* Pre-treatment cohorts only, then collapse to municipality level
*------------------------------------------------------------------------*
gen pre_treatment = 0
replace pre_treatment = 1 if state=="01" & cohort < 1990
replace pre_treatment = 1 if state=="10" & cohort < 1991
replace pre_treatment = 1 if state=="19" & cohort < 1987
replace pre_treatment = 1 if state=="25" & cohort < 1993
replace pre_treatment = 1 if state=="26" & cohort < 1993
replace pre_treatment = 1 if state=="28" & cohort < 1990
* Never-treated states: cohorts before the earliest treatment anywhere
replace pre_treatment = 1 if first_cohort==0 & cohort < 1987

keep if pre_treatment == 1

collapse (mean) female age student edu indigenous rural dmigrant inactive labor ///
         (first) engl state first_cohort [iw=factor], by(geo)

gen treated_mun = (engl==1 & first_cohort!=0)
encode state, gen(state_id)

*------------------------------------------------------------------------*
* Propensity score + minima-maxima common support (conservative)
*------------------------------------------------------------------------*
quietly logit treated_mun female age student edu indigenous rural dmigrant inactive labor i.state_id
predict pscore, pr

quietly sum pscore if treated_mun==1
local min_t = r(min)
local max_t = r(max)
quietly sum pscore if treated_mun==0
local min_c = r(min)
local max_c = r(max)

gen common_support = (pscore >= max(`min_t', `min_c') & pscore <= min(`max_t', `max_c'))

*------------------------------------------------------------------------*
* Standardized differences (pooled SD), before and after restriction
*   std_diff = (mean_treated - mean_control) / sqrt((sd_t^2 + sd_c^2)/2)
*------------------------------------------------------------------------*
local covlist female age student edu indigenous rural dmigrant inactive labor

foreach v of local covlist {
    * --- Before restriction (full sample) ---
    quietly sum `v' if treated_mun==0
    local c0_`v' = r(mean)
    local sc0_`v' = r(sd)
    quietly sum `v' if treated_mun==1
    local t0_`v' = r(mean)
    local st0_`v' = r(sd)
    local d0_`v' = (`t0_`v'' - `c0_`v'') / sqrt((`st0_`v''^2 + `sc0_`v''^2)/2)

    * --- After common support restriction ---
    quietly sum `v' if treated_mun==0 & common_support==1
    local cA_`v' = r(mean)
    local scA_`v' = r(sd)
    quietly sum `v' if treated_mun==1 & common_support==1
    local tA_`v' = r(mean)
    local stA_`v' = r(sd)
    local dA_`v' = (`tA_`v'' - `cA_`v'') / sqrt((`stA_`v''^2 + `scA_`v''^2)/2)
}

* Sample sizes (municipalities)
quietly count if treated_mun==0
local n_c0 = r(N)
quietly count if treated_mun==1
local n_t0 = r(N)
quietly count if treated_mun==0 & common_support==1
local n_cA = r(N)
quietly count if treated_mun==1 & common_support==1
local n_tA = r(N)

*------------------------------------------------------------------------*
* Write the LaTeX table (matches the publication style of the paper)
*------------------------------------------------------------------------*
local dol = char(36)                       // literal $ for math-mode std diffs
local labs `" "Female" "Age" "Student" "Education" "Indigenous" "Rural" "Migrant" "Inactive" "Labor Force" "'

capture file close fh
file open fh using "$tabs/balance_table.tex", write replace

file write fh "\begin{table}[ht!]" _n
file write fh "\centering" _n
file write fh "\caption{Covariate Balance Before and After Common Support Restriction}" _n
file write fh "\label{balanceTable}" _n
file write fh "\small" _n
file write fh "\begin{threeparttable}" _n
file write fh "\begin{tabular}{lccccccc}" _n
file write fh "\toprule" _n
file write fh "& \multicolumn{3}{c}{Before Restriction} & & \multicolumn{3}{c}{After Restriction} \\" _n
file write fh "\cmidrule{2-4} \cmidrule{6-8}" _n
file write fh "Covariate & Control & Treated & Std. Diff. & & Control & Treated & Std. Diff. \\" _n
file write fh "\midrule" _n

local i = 1
foreach v of local covlist {
    local lab : word `i' of `labs'

    local c0 : display %9.3f `c0_`v''
    local c0 = strtrim("`c0'")
    local t0 : display %9.3f `t0_`v''
    local t0 = strtrim("`t0'")
    local d0 : display %9.3f `d0_`v''
    local d0 = strtrim("`d0'")

    local cA : display %9.3f `cA_`v''
    local cA = strtrim("`cA'")
    local tA : display %9.3f `tA_`v''
    local tA = strtrim("`tA'")
    local dA : display %9.3f `dA_`v''
    local dA = strtrim("`dA'")

    file write fh "`lab' & `c0' & `t0' & `dol'`d0'`dol' & & `cA' & `tA' & `dol'`dA'`dol' \\" _n
    local i = `i' + 1
}

file write fh "\midrule" _n
file write fh "Observations & `n_c0' & `n_t0' & & & `n_cA' & `n_tA' & \\" _n
file write fh "\bottomrule" _n
file write fh "\end{tabular}" _n
file write fh "\begin{tablenotes}[flushleft]" _n
file write fh "\footnotesize" _n
file write fh "\item \textit{Note:} This table reports municipality-level means for pre-treatment covariates, comparing high-English (treated) and low-English (control) municipalities before and after imposing common support restrictions. Pre-treatment characteristics are calculated using cohorts born before the earliest program implementation in each state. Standardized differences are calculated as the difference in means divided by the pooled standard deviation. Values below 0.10 (in absolute value) indicate excellent balance; values below 0.25 indicate acceptable balance. Before restriction, treated and control municipalities differ significantly on most characteristics. After common support restriction, all standardized differences fall below 0.275, with no statistically significant differences remaining (all p-values `dol'>`dol' 0.35)." _n
file write fh "\end{tablenotes}" _n
file write fh "\end{threeparttable}" _n
file write fh "\end{table}" _n

file close fh

di as result ""
di as result "========== DONE =========="
di as result "Saved: $tabs/balance_table.tex"
di as result "Municipalities -> Before: `n_c0' control, `n_t0' treated | After: `n_cA' control, `n_tA' treated"

