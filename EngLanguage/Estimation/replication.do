*========================================================================*
* SECTION A: pretrend_summary.tex + pretrend_coef.tex
* OLS event-study pre-trend leads-and-lags, by outcome.
*========================================================================*

use "$data/labor_census20.dta", clear
drop if state=="05" | state=="17"
keep if migrant==0
drop if imputed_state==1

* Data cleaning: speaking implies understanding (paper Table 2 convention)
replace elengua=1 if hlengua==1

* Define treatment as before
sum hrs_exp2 if state=="01" & cohort>=1990 & cohort<=1996, d
gen engl=hrs_exp2>=r(p50) & state=="01"
sum hrs_exp2 if state=="10" & cohort>=1991 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="10"
sum hrs_exp2 if state=="19" & cohort>=1987 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="19"
sum hrs_exp2 if state=="25" & cohort>=1993 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="25"
sum hrs_exp2 if state=="26" & cohort>=1993 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="26"
sum hrs_exp2 if state=="28" & cohort>=1990 & cohort<=1996, d
replace engl=1 if hrs_exp2>=r(p50) & state=="28"

gen first_cohort=0
replace first_cohort=1990 if state=="01" & engl==1
replace first_cohort=1991 if state=="10" & engl==1
replace first_cohort=1987 if state=="19" & engl==1
replace first_cohort=1993 if state=="25" & engl==1
replace first_cohort=1993 if state=="26" & engl==1
replace first_cohort=1990 if state=="28" & engl==1

destring geo, replace

* Keep only pre-treatment cohorts
gen pre_treatment = 0
replace pre_treatment = 1 if state=="01" & cohort < 1990
replace pre_treatment = 1 if state=="10" & cohort < 1991
replace pre_treatment = 1 if state=="19" & cohort < 1987
replace pre_treatment = 1 if state=="25" & cohort < 1993
replace pre_treatment = 1 if state=="26" & cohort < 1993
replace pre_treatment = 1 if state=="28" & cohort < 1990
replace pre_treatment = 1 if first_cohort==0 & cohort < 1987

keep if pre_treatment == 1

* Collapse to municipality-cohort level
collapse (mean) elengua hlengua indigenous engl first_cohort ///
         female age student edu rural dmigrant inactive labor ///
         [iw=factor], by(geo cohort state)

* Define treatment indicator
gen treated_mun = (engl==1 & first_cohort!=0)

* For each municipality, calculate pre-treatment levels and trends
sort geo cohort

* Calculate municipality-level means (levels)
bysort geo: egen elengua_mean = mean(elengua)
bysort geo: egen hlengua_mean = mean(hlengua)
bysort geo: egen indigenous_mean = mean(indigenous)

* Calculate linear trends for each municipality
gen time_to_treat = cohort - first_cohort
replace time_to_treat = cohort - 1987 if first_cohort==0

foreach var in elengua hlengua indigenous {
    bysort geo: gen `var'_trend = .

    * Calculate trend using regression within each municipality
    levelsof geo, local(munis)
    foreach m of local munis {
        capture regress `var' time_to_treat if geo==`m'
        if _rc==0 {
            replace `var'_trend = _b[time_to_treat] if geo==`m'
        }
    }
}

* Keep one observation per municipality
bysort geo: keep if _n==1

* Keep relevant variables
keep geo treated_mun state elengua_mean hlengua_mean indigenous_mean ///
     elengua_trend hlengua_trend indigenous_trend ///
     female age student edu rural dmigrant inactive labor

* Encode state for fixed effects
encode state, gen(state_id)

*------------------------------------------------------------------------*
* Run all three regressions and store results
*------------------------------------------------------------------------*

* Test 1: Pre-treatment LEVELS  (built-in regress + estimates store; no estout)
estimates clear
regress treated_mun elengua_mean hlengua_mean indigenous_mean ///
        female age student edu rural dmigrant inactive labor ///
        i.state_id, vce(cluster state_id)
estimates store levels

test elengua_mean hlengua_mean indigenous_mean
local f_levels = r(F)
local p_levels = r(p)

* Test 2: Pre-treatment TRENDS
regress treated_mun elengua_trend hlengua_trend indigenous_trend ///
        female age student edu rural dmigrant inactive labor ///
        i.state_id, vce(cluster state_id)
estimates store trends

test elengua_trend hlengua_trend indigenous_trend
local f_trends = r(F)
local p_trends = r(p)

* Test 3: Joint test (LEVELS + TRENDS)
regress treated_mun elengua_mean hlengua_mean indigenous_mean ///
        elengua_trend hlengua_trend indigenous_trend ///
        female age student edu rural dmigrant inactive labor ///
        i.state_id, vce(cluster state_id)

test elengua_mean hlengua_mean indigenous_mean ///
     elengua_trend hlengua_trend indigenous_trend
local f_joint = r(F)
local p_joint = r(p)

di ""
di "F-levels=" %5.3f `f_levels' "  F-trends=" %5.3f `f_trends' "  F-joint=" %5.3f `f_joint'
di ""

*------------------------------------------------------------------------*
* Export pretrend_summary.tex (F-test summary), manual file write
* (reproduces the original listtex output; no external packages needed)
*------------------------------------------------------------------------*

local sfL = string(`f_levels', "%5.3f")
if substr("`sfL'",1,1)=="." local sfL "0`sfL'"
local spL = string(`p_levels', "%5.3f")
if substr("`spL'",1,1)=="." local spL "0`spL'"
local sfT = string(`f_trends', "%5.3f")
if substr("`sfT'",1,1)=="." local sfT "0`sfT'"
local spT = string(`p_trends', "%5.3f")
if substr("`spT'",1,1)=="." local spT "0`spT'"
local sfJ = string(`f_joint', "%5.3f")
if substr("`sfJ'",1,1)=="." local sfJ "0`sfJ'"
local spJ = string(`p_joint', "%5.3f")
if substr("`spJ'",1,1)=="." local spJ "0`spJ'"

capture file close fh_ps
