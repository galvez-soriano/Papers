*========================================================================*
*  2020 census, percentile-threshold sensitivity
*    Re-estimates the simple ATT (understanding / speaking / identity)
*    across treatment-cutoff percentiles 46-54 (canonical = p50) and plots
*    the ATT +/- 95% CI vs. percentile. (Source also evaluates p75 but
*    drops it from the plot; the percentile CSV export is omitted.)
*========================================================================*
cap graph set window fontface "Times New Roman"
set scheme s2mono
grstyle init
grstyle set plain, horizontal grid
grstyle set color navy midblue*.8
grstyle set symbol, n(4)
grstyle set legend 6, nobox

use "$data/labor_census20.dta", clear
drop if state=="05" | state=="17"
keep if migrant==0
drop if imputed_state==1
destring geo, replace

* speaking implies understanding (paper Table 2 spec)
replace elengua=1 if hlengua==1

tempfile maindata
save `maindata'

* Percentiles to test
local plist 46 47 48 49 50 51 52 53 54 75

* Postfile to collect simple-ATT estimates at each threshold
capture postclose pf_sens
tempfile sens_estimates
postfile pf_sens pct b_el se_el b_hl se_hl b_in se_in using "`sens_estimates'"

foreach p of local plist {

    di as result "=== Percentile `p' ==="

    use `maindata', clear

    * Treatment: per-state cohort-window percentile cut of hrs_exp2
    _pctile hrs_exp2 if state=="01" & cohort>=1990 & cohort<=1996, p(`p')
    local cut01 = r(r1)
    _pctile hrs_exp2 if state=="10" & cohort>=1991 & cohort<=1996, p(`p')
    local cut10 = r(r1)
    _pctile hrs_exp2 if state=="19" & cohort>=1987 & cohort<=1996, p(`p')
    local cut19 = r(r1)
    _pctile hrs_exp2 if state=="25" & cohort>=1993 & cohort<=1996, p(`p')
    local cut25 = r(r1)
    _pctile hrs_exp2 if state=="26" & cohort>=1993 & cohort<=1996, p(`p')
    local cut26 = r(r1)
    _pctile hrs_exp2 if state=="28" & cohort>=1990 & cohort<=1996, p(`p')
    local cut28 = r(r1)

    gen engl = hrs_exp2>=`cut01' & state=="01"
    replace engl=1 if hrs_exp2>=`cut10' & state=="10"
    replace engl=1 if hrs_exp2>=`cut19' & state=="19"
    replace engl=1 if hrs_exp2>=`cut25' & state=="25"
    replace engl=1 if hrs_exp2>=`cut26' & state=="26"
    replace engl=1 if hrs_exp2>=`cut28' & state=="28"

    gen first_cohort=0
    replace first_cohort=1990 if state=="01" & engl==1
    replace first_cohort=1991 if state=="10" & engl==1
    replace first_cohort=1987 if state=="19" & engl==1
    replace first_cohort=1993 if state=="25" & engl==1
    replace first_cohort=1993 if state=="26" & engl==1
    replace first_cohort=1990 if state=="28" & engl==1

    csdid elengua edu rural female dmigrant [iw=factor], ///
        time(cohort) gvar(first_cohort) method(dripw) vce(cluster geo) long2 wboot seed(6)
    estat simple
    matrix T = r(table)
    scalar b_el  = T[1,1]
    scalar se_el = T[2,1]

    csdid hlengua edu rural female dmigrant [iw=factor], ///
        time(cohort) gvar(first_cohort) method(dripw) vce(cluster geo) long2 wboot seed(6)
    estat simple
    matrix T = r(table)
    scalar b_hl  = T[1,1]
    scalar se_hl = T[2,1]

    csdid indigenous edu rural female dmigrant [iw=factor], ///
        time(cohort) gvar(first_cohort) method(dripw) vce(cluster geo) long2 wboot seed(6)
    estat simple
    matrix T = r(table)
    scalar b_in  = T[1,1]
    scalar se_in = T[2,1]

    post pf_sens (`p') (b_el) (se_el) (b_hl) (se_hl) (b_in) (se_in)
}

postclose pf_sens

*--- Sensitivity graphs ---*
preserve
use "`sens_estimates'", clear

drop if pct == 75

foreach o in el hl in {
    gen lb_`o' = b_`o' - 1.96*se_`o'
    gen ub_`o' = b_`o' + 1.96*se_`o'
}

local grap_opts xlabel(46(1)54, grid) xtitle("Percentile threshold") ///
    xline(50, lpattern(dash) lcolor(red) lwidth(medium)) ///
    yline(0, lpattern(solid) lcolor(gs8)) ///
    graphregion(color(white)) plotregion(color(white)) ///
    ylabel(, labs(small) grid format(%5.3f))

twoway (rcap lb_el ub_el pct, lcolor(navy) lwidth(medium)) ///
       (scatter b_el pct, mcolor(navy) msymbol(O) msize(medium)), ///
    ytitle("ATT: Understands indigenous language", size(medium) height(5)) ///
    legend(off) `grap_opts'
graph export "$figs/Sensitivity_Understanding.png", replace width(2000)

twoway (rcap lb_hl ub_hl pct, lcolor(navy) lwidth(medium)) ///
       (scatter b_hl pct, mcolor(navy) msymbol(O) msize(medium)), ///
    ytitle("ATT: Speaks indigenous language", size(medium) height(5)) ///
    legend(off) `grap_opts'
graph export "$figs/Sensitivity_Speaking.png", replace width(2000)

twoway (rcap lb_in ub_in pct, lcolor(navy) lwidth(medium)) ///
       (scatter b_in pct, mcolor(navy) msymbol(O) msize(medium)), ///
    ytitle("ATT: Indigenous self-identification", size(medium) height(5)) ///
    legend(off) `grap_opts'
graph export "$figs/Sensitivity_Identity.png", replace width(2000)

restore

}   // end PART 2 (figures)

